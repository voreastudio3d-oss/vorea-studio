{
  "name": "vorea-parametrics-3d",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build && npx tsx scripts/generate-static-seo-assets.ts",
    "build:server": "npx tsx --tsconfig tsconfig.json server/server.ts",
    "dev": "vite",
    "dev:api": "tsx --env-file=.env --watch server/server.ts",
    "dev:all": "powershell -ExecutionPolicy Bypass -File scripts/dev-start.ps1",
    "dev:kill": "powershell -ExecutionPolicy Bypass -File scripts/dev-start.ps1 -Kill",
    "dev:all:mac": "bash scripts/dev-start.sh",
    "dev:kill:mac": "bash scripts/dev-start.sh --kill",
    "lint": "eslint src server scripts utils --ext .ts,.tsx,.js,.mjs --ignore-pattern \"scripts/**/*.cjs\" --quiet",
    "start": "tsx --env-file=.env server/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:repo": "tsc --noEmit -p tsconfig.typecheck.json",
    "agent:sync": "npx tsx scripts/agents/sync.ts",
    "agent:route": "npx tsx scripts/agents/route.ts",
    "agent:preflight": "npx tsx scripts/agents/preflight.ts",
    "agent:git-recover": "npx tsx scripts/agents/git-recover.ts",
    "agent:governance:check": "npx tsx scripts/agents/governance-check.ts",
    "docs:api:generate": "node scripts/generate-api-docs.mjs",
    "docs:api:check": "node scripts/check-api-docs-parity.mjs",
    "docs:api": "npm run docs:api:generate && npm run docs:api:check",
    "qa:relief:assets": "node --import tsx scripts/generate-relief-smoke-assets.ts",
    "qa:smoke": "npx tsx scripts/verify-admin-smoke.ts",
    "verify:deploy:routing-seo": "npx tsx scripts/verify-deploy-routing-seo.ts",
    "verify:monetization:tiers": "npx tsx scripts/verify-monetization-tiers.ts",
    "smoke:ai-studio:railway": "npx tsx scripts/smoke-ai-studio-railway.ts",
    "news:ingest": "npx tsx --env-file=.env scripts/news-ingest.ts",
    "news:cleanup": "npx tsx --env-file=.env scripts/news-cleanup.ts",
    "news:seed-sources": "npx tsx --env-file=.env scripts/seed-news-sources.ts",
    "backfill:community:dry": "npx tsx server/backfill-community-kv-to-prisma.ts --dry-run",
    "backfill:community:apply": "npx tsx server/backfill-community-kv-to-prisma.ts --apply",
    "reset:community": "npx tsx --env-file=.env scripts/reset-dev-community.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
