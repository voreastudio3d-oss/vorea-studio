# ═══════════════════════════════════════════════════════════════
# Vorea Studio — Environment Variables
# Copy this file to .env and fill in the values.
# ═══════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PORT=3001
DEPLOY_SECRET=

# ─── Database (PostgreSQL) ────────────────────────────────────
# Railway provides DATABASE_URL automatically when you add a Postgres service
DATABASE_URL=postgresql://vorea:vorea_dev@localhost:5432/vorea_studio?schema=public

# ─── Community DB Mode ────────────────────────────────────────
# kv     = read/write community in kv_store (legacy)
# dual   = write to kv_store + prisma tables, read from kv_store
# prisma = read/write community from prisma-backed tables (recommended)
COMMUNITY_DB_MODE=prisma

# ─── Auth (JWT) ───────────────────────────────────────────────
JWT_SECRET=your-strong-random-secret-at-least-32-chars
JWT_EXPIRY=7d

# ─── BYOK Vault Encryption ───────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=

# ─── Owner / SuperAdmin ──────────────────────────────────────
VITE_OWNER_EMAIL=vorea.studio3d@gmail.com

# ─── Google OAuth (One Tap / Sign In With Google) ─────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── PayPal ───────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
# Change to "live" for production payments

# Webhook ID (from PayPal Developer Dashboard)
PAYPAL_WEBHOOK_ID=

# Subscription Plan IDs
PAYPAL_PRO_MONTHLY_PLAN_ID=
PAYPAL_PRO_YEARLY_PLAN_ID=
PAYPAL_STUDIOPRO_MONTHLY_PLAN_ID=
PAYPAL_STUDIOPRO_YEARLY_PLAN_ID=

# ─── Frontend (Return URLs) ──────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── AI Engine (Primary: Gemini) ─────────────────────────────
# Used by: AI Studio SCAD generation, Feedback AI Review, Analytics Insights, Quick Fix
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# ─── AI Engine (Optional: Multi-LLM Providers) ──────────────
# Enable additional LLM providers for AI Studio generation.
# The active provider is selected from the Admin Panel (admin:ai_config in KV).
# Only providers with valid API keys will appear as available options.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=

# ─── Resend (Transactional Emails) ───────────────────────────
RESEND_API_KEY=

# ─── News / Cron ─────────────────────────────────────────────
NEWS_CRON_SECRET=
NEWS_MAX_ITEMS_PER_SOURCE=6

# ─── Frontend (Vite build-time vars) ─────────────────────────
VITE_API_URL=/api

# ─── Google Analytics 4 (Client-side tracking) ───────────────
# Create a GA4 property at https://analytics.google.com
VITE_GA4_MEASUREMENT_ID=

# ─── GA4 Data API (Server-side, for Analytics Insights) ──────
# See docs/ga4-setup-guide.md for setup instructions
# Property ID from GA4 Admin → Property Settings
GA4_PROPERTY_ID=
# Service Account JSON key (single line, from Google Cloud Console)
# See docs/ga4-setup-guide.md for how to create and download
GA4_SERVICE_ACCOUNT_KEY=

